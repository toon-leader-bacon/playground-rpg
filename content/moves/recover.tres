[gd_resource type="Resource" load_steps=4 format=3]

[ext_resource type="Script" path="res://schema/monsters/MoveConfig.gd" id="1_mc"]
[ext_resource type="Script" path="res://schema/battle/NodeOverrideEntry.gd" id="2_noe"]

[sub_resource type="Resource" id="NodeOverride_acc"]
script = ExtResource("2_noe")
node_id = "ACCURACY_CHECK"
override_tag = "always_hit"

[resource]
script = ExtResource("1_mc")
id = "recover"
display_name = "Recover"
type_tag = 1
move_power = 0
accuracy = 1.0
pp = 10
target_mode = 2
node_overrides = [SubResource("NodeOverride_acc")]
heal_formula = "target.max_hp * 0.5"

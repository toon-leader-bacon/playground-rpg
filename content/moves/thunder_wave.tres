[gd_resource type="Resource" load_steps=6 format=3]

[ext_resource type="Script" path="res://schema/monsters/MoveConfig.gd" id="1_mc"]
[ext_resource type="Script" path="res://schema/battle/EffectEntry.gd" id="2_ee"]
[ext_resource type="Script" path="res://schema/battle/NodeOverrideEntry.gd" id="3_noe"]

[sub_resource type="Resource" id="EffectEntry_paralysis"]
script = ExtResource("2_ee")
chance = 1.0
target = "target"
condition_id = "paralysis"

[sub_resource type="Resource" id="NodeOverride_acc"]
script = ExtResource("3_noe")
node_id = "ACCURACY_CHECK"
override_tag = "always_hit"

[resource]
script = ExtResource("1_mc")
id = "thunder_wave"
display_name = "Thunder Wave"
type_tag = 5
move_power = 0
accuracy = 0.9
pp = 20
target_mode = 0
node_overrides = [SubResource("NodeOverride_acc")]
post_effects = [SubResource("EffectEntry_paralysis")]
